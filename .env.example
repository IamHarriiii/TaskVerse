# ─── TaskVerse Environment Configuration ───
# Copy this file to .env and customise as needed.

# App
APP_NAME=TaskVerse
APP_VERSION=2.0.0
DEBUG=false

# API Server
API_HOST=0.0.0.0
API_PORT=8000

# CORS (comma-separated origins)
CORS_ORIGINS=["*"]

# JWT Auth – CHANGE THIS IN PRODUCTION!
SECRET_KEY=taskverse-dev-secret-change-me-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Frontend
API_BASE_URL=http://localhost:8000
